{
  "name": "andyai-operational-memory",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "export:bundle": "tsx src/export-bundle.ts",
    "verify:bundle": "tsx src/verify-bundle.ts",
    "replay:export": "tsx src/replay.ts",
    "trust:validate-bundles": "node scripts/validate-trust-bundle.mjs",
    "trust:validate-replay": "node scripts/validate-replay-manifest.mjs",
    "trust:release-manifest": "node scripts/generate-release-manifest.mjs",
    "trust:report": "node scripts/generate-trust-report.mjs",
    "trust:all": "npm run trust:validate-bundles && npm run trust:validate-replay && npm run trust:release-manifest && npm run trust:report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
