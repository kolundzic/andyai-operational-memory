{
  "name": "andyai-operational-memory",
  "version": "1.0.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts",
    "check": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs",
    "test:trust": "node --test tests/trust/**/*.test.mjs",
    "verify:trust-folder": "node scripts/verify-trust-folder.mjs",
    "export:bundle": "tsx src/export-bundle.ts",
    "verify:bundle": "tsx src/verify-bundle.ts",
    "replay:export": "tsx src/replay.ts",
    "trust:validate-bundles": "node scripts/validate-trust-bundle.mjs",
    "trust:validate-replay": "node scripts/validate-replay-manifest.mjs",
    "trust:release-manifest": "node scripts/generate-release-manifest.mjs",
    "trust:report": "node scripts/generate-trust-report.mjs",
    "trust:all": "npm run trust:validate-bundles && npm run trust:validate-replay && npm run trust:release-manifest && npm run trust:report",
    "release:prepare": "node scripts/prepare-release-folders.mjs",
    "release:stage": "node scripts/stage-trust-artifacts.mjs",
    "release:build-log": "node scripts/generate-build-log.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release:summary": "node scripts/generate-release-summary.mjs",
    "release:pack": "node scripts/pack-release.mjs",
    "release:all": "npm run check && npm run test && npm run verify:trust-folder && npm run trust:all && npm run release:prepare && npm run release:stage && npm run release:build-log && npm run release:notes && npm run release:summary && npm run release:pack"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}