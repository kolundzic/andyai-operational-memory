{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReplayManifest",
  "type": "object",
  "required": ["version", "exported_at", "count", "items"],
  "properties": {
    "version": { "type": "string" },
    "exported_at": { "type": "string" },
    "count": { "type": "integer" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "trust_level", "checksum"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "trust_level": { "type": "string" },
          "checksum": { "type": "string" }
        }
      }
    }
  }
}
