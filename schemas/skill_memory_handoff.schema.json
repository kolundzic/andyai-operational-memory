{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillMemoryHandoff",
  "type": "object",
  "required": [
    "skill_id",
    "run_id",
    "project_id",
    "status",
    "summary",
    "result",
    "recommended_memory_type",
    "recommended_tags"
  ],
  "properties": {
    "skill_id": { "type": "string" },
    "run_id": { "type": "string" },
    "project_id": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "result": { "type": "object" },
    "evidence": {
      "type": "object",
      "properties": {
        "log_path": { "type": "string" },
        "artifact_path": { "type": "string" },
        "checksum": { "type": "string" }
      }
    },
    "recommended_memory_type": {
      "type": "string",
      "enum": ["decision", "case", "pattern", "preference", "plan", "reference"]
    },
    "recommended_tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
