{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReleaseManifest",
  "type": "object",
  "required": ["version", "generated_at", "bundles", "replay_manifests", "reports"],
  "properties": {
    "version": { "type": "string" },
    "generated_at": { "type": "string" },
    "bundles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "replay_manifests": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reports": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
